<style>
	html { scroll-behavior: smooth; }
	body { font-family: 'Inter', system-ui, sans-serif; }
	/* Subtle mathematical grid backdrop for hero */
	.math-grid {
		background-image:
			linear-gradient(to right, rgba(255,255,255,0.06) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(255,255,255,0.06) 1px, transparent 1px);
		background-size: 56px 56px;
	}
	/* Decorative gradient ring for hero accent */
	.ring-glow {
		background: radial-gradient(circle at 30% 30%, rgba(200,164,92,0.35), transparent 60%),
								radial-gradient(circle at 70% 70%, rgba(56,116,203,0.35), transparent 55%);
		filter: blur(40px);
	}
	/* Skip link visibility */
	.skip-link:focus { transform: translateY(0); }
</style>
