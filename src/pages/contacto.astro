---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import ContactForm from "../components/forms/ContactForm.astro";

const disabled = Astro.url.searchParams.get("disabled") === "true";
---

<Layout>
  <div class="bg-cream text-ink antialiased">
    <Navbar />

    <main>
      <section id="contacto" class="border-b border-line py-24 lg:py-32">
        <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-12 lg:px-8">
          <div class="lg:col-span-5">
            <p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-accent">
              08 — Contacto
            </p>

            <h1 class="font-serif text-3xl font-semibold leading-tight text-navy lg:text-5xl">
              Escríbenos.
            </h1>

            <p class="mt-6 text-lg leading-relaxed text-ink/70">
              Completa el formulario con tu nombre, correo y mensaje. Por ahora,
              el envío automático está temporalmente deshabilitado mientras
              terminamos el despliegue.
            </p>

            <div class="mt-8 rounded-2xl border border-line bg-white p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">
                Contacto directo
              </p>

              <a
                href="mailto:siamchaptercali@gmail.com"
                class="mt-3 block font-serif text-2xl text-navy underline decoration-accent underline-offset-4"
              >
                siamchaptercali@gmail.com
              </a>

              <p class="mt-3 text-sm leading-relaxed text-ink/70">
                Mientras activamos el formulario, puedes escribir directamente
                al correo oficial del capítulo.
              </p>
            </div>

            <dl class="mt-10 space-y-5 text-[0.95rem]">
              <div class="grid grid-cols-3 gap-4">
                <div>
                  <dt class="text-xs uppercase tracking-widest text-ink/50">
                    Instagram
                  </dt>
                  <dd class="mt-1 font-serif italic text-ink/40">
                    Próximamente
                  </dd>
                </div>

                <div>
                  <dt class="text-xs uppercase tracking-widest text-ink/50">
                    LinkedIn
                  </dt>
                  <dd class="mt-1 font-serif italic">
                    <a
                      href="https://www.linkedin.com/company/siamchaptercali/"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="break-words text-navy underline underline-offset-4 hover:text-navy/80"
                    >
                      SIAM Chapter Cali
                    </a>
                  </dd>
                </div>

                <div>
                  <dt class="text-xs uppercase tracking-widest text-ink/50">
                    GitHub
                  </dt>
                  <dd class="mt-1 font-serif italic text-ink/40">
                    Próximamente
                  </dd>
                </div>
              </div>
            </dl>
          </div>

          <div class="lg:col-span-7">
            {disabled && (
              <div class="mb-6 rounded-2xl border border-accent/40 bg-white p-5 text-ink">
                <p class="font-semibold text-navy">
                  El formulario está temporalmente deshabilitado.
                </p>
                <p class="mt-2 text-sm leading-relaxed text-ink/70">
                  Por ahora, por favor escribe directamente a
                  <a
                    href="mailto:siamchaptercali@gmail.com"
                    class="ml-1 font-semibold text-navy underline decoration-accent underline-offset-4"
                  >
                    siamchaptercali@gmail.com
                  </a>.
                </p>
              </div>
            )}

            <ContactForm />
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
