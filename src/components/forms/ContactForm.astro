<form method="POST" action="/api/contact" class="space-y-5 rounded-2xl border border-line bg-white p-7 lg:p-10">
  <div>
    <label for="name" class="mb-2 block text-sm font-medium text-ink/80">
      Nombre
    </label>
    <input id="name" name="name" type="text" required class="w-full rounded-lg border border-line bg-cream/40 px-4 py-3 text-ink transition focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/30" placeholder="Tu nombre completo" />
  </div>

  <div>
    <label for="email" class="mb-2 block text-sm font-medium text-ink/80">
      Correo electrónico
    </label>
    <input id="email" name="email" type="email" required class="w-full rounded-lg border border-line bg-cream/40 px-4 py-3 text-ink transition focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/30" placeholder="tu@correo.com" />
  </div>

  <div>
    <label for="subject" class="mb-2 block text-sm font-medium text-ink/80">
      Asunto
    </label>
    <input id="subject" name="subject" type="text" required class="w-full rounded-lg border border-line bg-cream/40 px-4 py-3 text-ink transition focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/30" placeholder="Quiero contactar al capítulo" />
  </div>

  <div>
    <label for="type" class="mb-2 block text-sm font-medium text-ink/80">
      Tipo de mensaje
    </label>
    <select id="type" name="type" class="w-full rounded-lg border border-line bg-cream/40 px-4 py-3 text-ink transition focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/30">
      <option>Información general</option>
      <option>Proponer una charla</option>
      <option>Unirse al capítulo</option>
      <option>Colaboración institucional</option>
      <option>Otro</option>
    </select>
  </div>

  <div>
    <label for="message" class="mb-2 block text-sm font-medium text-ink/80">
      Mensaje
    </label>
    <textarea id="message" name="message" rows="5" required class="w-full resize-none rounded-lg border border-line bg-cream/40 px-4 py-3 text-ink transition focus:border-navy focus:outline-none focus:ring-2 focus:ring-navy/30" placeholder="Cuéntanos sobre ti y tu interés en el capítulo"></textarea>
  </div>

  <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-navy px-7 py-3 font-semibold text-cream transition hover:bg-deep">
    Enviar mensaje
    <span aria-hidden="true">→</span>
  </button>
</form>
