---
const { resource } = Astro.props;
const href = resource?.fileUrl || resource?.url;
---

<li class="flex flex-col gap-5 rounded-xl border border-line p-6 sm:flex-row">
  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-navy font-serif text-cream">
    {resource?.category === "link" ? "↗" : "📚"}
  </div>

  <div class="flex-1">
    <h3 class="font-serif text-lg font-semibold text-navy">
      {resource.title}
    </h3>

    {resource.description && (
      <p class="mt-2 text-[0.95rem] leading-relaxed text-ink/75">
        {resource.description}
      </p>
    )}

    {href && (
      <a href={href} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-navy transition hover:text-accent">
        Abrir recurso
        <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
</li>
