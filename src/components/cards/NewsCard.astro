---
const { post } = Astro.props;

const date = post?.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("es-CO", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<article class="overflow-hidden rounded-2xl border border-line bg-white transition hover:-translate-y-1 hover:shadow-lg">
  {post?.coverImageUrl && (
    <img src={post.coverImageUrl} alt={post.title} class="h-56 w-full object-cover" />
  )}

  <div class="p-7">
    <div class="mb-4 flex flex-wrap items-center gap-3">
      {post?.category && (
        <span class="text-xs font-semibold uppercase tracking-wide text-accent">
          {post.category}
        </span>
      )}
      {date && (
        <>
          <span class="text-ink/40">·</span>
          <time class="text-sm text-ink/70">{date}</time>
        </>
      )}
    </div>

    <h3 class="font-serif text-xl font-semibold text-navy">
      {post.title}
    </h3>

    {post?.excerpt && (
      <p class="mt-3 text-[0.95rem] leading-relaxed text-ink/75">
        {post.excerpt}
      </p>
    )}

    <a href={`/noticias/${post.slug}`} class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-navy transition hover:text-accent">
      Leer noticia
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
