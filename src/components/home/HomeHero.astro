---
const { settings } = Astro.props;
---

<section id="inicio" class="relative overflow-hidden bg-navy text-cream">
  <div class="absolute inset-0 math-grid opacity-50" aria-hidden="true"></div>
  <div class="absolute -right-32 -top-32 h-[480px] w-[480px] rounded-full ring-glow" aria-hidden="true"></div>
  <div class="absolute -bottom-40 -left-32 h-[420px] w-[420px] rounded-full ring-glow" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-5 py-24 lg:px-8 lg:py-36">
    <p class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-accent lg:text-sm">
      Capítulo Estudiantil · Cali, Colombia
    </p>

    <h1 class="max-w-4xl font-serif text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-7xl">
      {settings?.heroTitle || "Capítulo Estudiantil"}
      <span class="block text-accent">SIAM Cali</span>
    </h1>

    <p class="mt-8 max-w-2xl font-serif text-xl italic leading-relaxed text-cream/85 lg:text-2xl">
      “Matemáticas que conectan disciplinas, ideas que transforman realidades.”
    </p>

    <p class="mt-6 max-w-xl text-base leading-relaxed text-cream/70 lg:text-lg">
      {settings?.heroSubtitle ||
        "Una comunidad interdisciplinar de la Pontificia Universidad Javeriana Cali y la Institución Universitaria Antonio José Camacho, dedicada a las matemáticas aplicadas y la computación científica."}
    </p>

    <div class="mt-10 flex flex-wrap gap-4">
      <a href="#nosotros" class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3 font-semibold text-deep transition hover:bg-accent/90">
        Conócenos
        <span aria-hidden="true">→</span>
      </a>
      <a href="/contacto" class="inline-flex items-center gap-2 rounded-full border border-cream/30 px-7 py-3 font-semibold text-cream transition hover:bg-cream/10">
        Únete al capítulo
      </a>
    </div>

    <div class="mt-20 grid max-w-3xl gap-6 border-t border-cream/15 pt-8 sm:grid-cols-2">
      <div>
        <p class="mb-1 text-xs uppercase tracking-widest text-cream/50">
          Universidad participante
        </p>
        <p class="font-serif text-lg text-cream">
          Pontificia Universidad Javeriana Cali
        </p>
      </div>
      <div>
        <p class="mb-1 text-xs uppercase tracking-widest text-cream/50">
          Universidad participante
        </p>
        <p class="font-serif text-lg text-cream">
          Institución Universitaria Antonio José Camacho
        </p>
      </div>
    </div>
  </div>
</section>
