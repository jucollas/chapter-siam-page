---
const areas = [
  {
    number: "4.1",
    title: "Inteligencia Artificial y Aprendizaje Automático",
    description:
      "Diseño y entrenamiento de modelos de aprendizaje automático para problemas reales: clasificación de imágenes médicas para detección de cáncer, redes neuronales convolucionales (CNN), deep learning y automatización de procesos como la gestión de campañas en redes sociales.",
  },
  {
    number: "4.2",
    title: "Modelado y Simulación Computacional",
    description:
      "Representación y análisis de fenómenos dinámicos: modelos de opinión dinámicos y no dinámicos, simulación de sistemas complejos, modelos de expansión tumoral y ecuaciones diferenciales aplicadas a la economía.",
  },
  {
    number: "4.3",
    title: "Biotecnología y Ciencias de la Vida",
    description:
      "Matemáticas al servicio de la biología y la medicina: diferenciación de células madre, detección y monitoreo de tumores, clasificación de imágenes biomédicas y patrones asociados a ataques epilépticos.",
  },
  {
    number: "4.4",
    title: "Sistemas Inteligentes y Tecnología Social",
    description:
      "Tecnología al servicio de las personas: traductor de lengua de señas basado en IA, soluciones para la detección de condiciones neurológicas y modelos matemáticos que reducen barreras y generan inclusión.",
  },
  {
    number: "4.5",
    title: "Automatización y Agroinformática",
    description:
      "Sensores, modelos computacionales e IA para optimizar procesos agrícolas e industriales: monitoreo de cultivos en tiempo real, riego inteligente según condiciones ambientales, análisis de evaporación y aprovechamiento de la radiación solar.",
  },
  {
    number: "4.6",
    title: "Matemáticas Discretas, Logica y Teoria del la Computacion",
    description:
      "La belleza formal de las matemáticas: programación competitiva, combinatoria, complejidad computacional y teoría de NP-completitud. El lugar donde el pensamiento lógico y el rigor se ponen a prueba.",
  },
];
---

<section id="areas" class="border-b border-line py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="max-w-3xl">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-accent">
        03 — Líneas de investigación
      </p>
      <h2 class="font-serif text-3xl font-semibold leading-tight text-navy lg:text-5xl">
        Siete áreas, una misma curiosidad.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-ink/70">
        Estas áreas reflejan los intereses y proyectos actuales de nuestros integrantes, y son el punto de partida para nuevas colaboraciones, proyectos y discusiones dentro del grupo.
      </p>
    </div>

    <div class="mt-16 grid overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
      {areas.map((area) => (
        <article class="bg-cream p-8 transition hover:bg-white">
          <span class="font-serif text-sm font-semibold text-accent">
            {area.number}
          </span>
          <h3 class="mt-2 font-serif text-xl font-semibold text-navy">
            {area.title}
          </h3>
          <p class="mt-4 text-[0.95rem] leading-relaxed text-ink/75">
            {area.description}
          </p>
        </article>
      ))}

      <article class="bg-cream p-8 transition hover:bg-white lg:col-span-3 lg:flex lg:items-start lg:gap-10">
        <div class="lg:w-1/3">
          <span class="font-serif text-sm font-semibold text-accent">4.7</span>
          <h3 class="mt-2 font-serif text-xl font-semibold text-navy">
            Economía Cuantitativa y Mercados
          </h3>
        </div>
        <p class="mt-4 text-[0.95rem] leading-relaxed text-ink/75 lg:mt-0 lg:flex-1">
          Estudiamos sistemas económicos a través de herramientas matemáticas: modelado de mercados globales, análisis de flujo en medios porosos con aplicaciones a la economía y ecuaciones diferenciales para representar dinámicas económicas publicadas en artículos especializados. Conectamos teoría económica con computación científica.
        </p>
      </article>
    </div>
  </div>
</section>
