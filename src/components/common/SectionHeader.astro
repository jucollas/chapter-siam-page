---
const { eyebrow, title, description, linkHref, linkLabel } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && (
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-accent">
      {eyebrow}
    </p>
  )}

  <h2 class="font-serif text-3xl font-semibold leading-tight text-navy lg:text-5xl">
    {title}
  </h2>

  {description && (
    <p class="mt-6 text-lg leading-relaxed text-ink/70">
      {description}
    </p>
  )}

  {linkHref && linkLabel && (
    <a href={linkHref} class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-navy transition hover:text-accent">
      {linkLabel}
      <span aria-hidden="true">→</span>
    </a>
  )}
</div>
