---
const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/#nosotros", label: "Quiénes somos" },
  { href: "/#mision", label: "Misión" },
  { href: "/#areas", label: "Áreas" },
  { href: "/eventos", label: "Actividades" },
  { href: "/equipo", label: "Integrantes" },
  { href: "/recursos", label: "Recursos" },
  { href: "/contacto", label: "Contacto" },
];
---

<header class="sticky top-0 z-40 border-b border-line bg-cream/85 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 lg:px-8" aria-label="Navegación principal">
    <a href="/" class="flex items-center gap-2 group">
      <img src="/favicon-2.svg" alt="SIAM Cali" class="h-20 w-20" />
      <span class="font-serif text-lg font-semibold text-navy">
        SIAM Cali
      </span>
    </a>

    <ul class="hidden items-center gap-8 text-sm font-medium text-ink/75 lg:flex">
      {navItems.slice(1).map((item) => (
        <li>
          <a class="transition hover:text-navy" href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contacto" class="inline-flex items-center gap-1.5 rounded-full bg-navy px-4 py-2 text-sm font-medium text-cream transition hover:bg-deep">
      Únete
      <span aria-hidden="true">→</span>
    </a>
  </nav>
</header>
