---
const { value = [] } = Astro.props;

function textFromChildren(children = []) {
  return children.map((child) => child.text || "").join("");
}
---

<div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-ink prose-p:text-ink/75 prose-a:text-navy prose-a:decoration-accent">
  {value.map((block) => {
    if (block._type === "image" && block.imageUrl) {
      return (
        <img
          src={block.imageUrl}
          alt=""
          class="my-8 rounded-3xl border border-line"
        />
      );
    }

    if (block._type !== "block") return null;

    const text = textFromChildren(block.children);

    if (block.style === "h2") {
      return <h2>{text}</h2>;
    }

    if (block.style === "h3") {
      return <h3>{text}</h3>;
    }

    if (block.listItem === "bullet") {
      return <li>{text}</li>;
    }

    if (block.listItem === "number") {
      return <li>{text}</li>;
    }

    return <p>{text}</p>;
  })}
</div>
